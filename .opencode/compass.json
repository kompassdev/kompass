{
  "$schema": "https://opencode.ai/schemas/compass.json",
  "commands": {
    "enabled": [
      "pr/create",
      "pr/review",
      "pr/fix",
      "ticket/plan",
      "ticket/dev",
      "review",
      "dev",
      "commit",
      "commit-and-push",
      "learn",
      "rmslop"
    ]
  },
  "agents": {
    "enabled": ["reviewer", "planner"]
  },
  "tools": {
    "enabled": ["changes_load", "pr_load", "ticket_load", "ticket_create"]
  },
  "components": {
    "enabled": ["change-summary", "commit", "dev-flow"]
  },
  "defaults": {
    "baseBranch": "main",
    "agentMode": "all"
  }
}
