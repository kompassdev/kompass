{
  "$schema": "https://raw.githubusercontent.com/kompassdev/kompass/main/kompass.schema.json",
  "commands": {
    "enabled": [
      "pr/create",
      "pr/review",
      "pr/fix",
      "ticket/create",
      "ticket/plan",
      "ticket/dev",
      "review",
      "dev",
      "commit",
      "commit-and-push",
      "learn",
      "rmslop"
    ]
  },
  "agents": {
    "enabled": ["reviewer", "planner"]
  },
  "tools": {
    "changes_load": {
      "enabled": true
    },
    "pr_load": {
      "enabled": true
    },
    "ticket_load": {
      "enabled": true
    },
    "ticket_sync": {
      "enabled": true
    }
  },
  "components": {
    "enabled": ["change-summary", "commit", "dev-flow"]
  },
  "defaults": {
    "baseBranch": "main"
  },
  "adapters": {
    "opencode": {
      "agentMode": "all"
    }
  }
}
