{
  "$schema": "https://opencode.ai/schemas/compass.json",
  "_comment": "Configuration for Compass. Place this file at .compass/config.json or compass.json in your project root. Legacy OpenCode-specific paths are still supported.",

  "commands": {
    "enabled": ["commit", "commit-and-push", "dev", "learn", "pr/create", "pr/fix", "pr/review", "review", "rmslop", "ticket/dev", "ticket/plan"],
    "templates": {
      "pr/create": "custom/path/to/pr-create.txt"
    }
  },

  "agents": {
    "enabled": ["planner", "reviewer"],
    "reviewer": {
      "description": "Custom reviewer description",
      "promptPath": "custom/path/to/reviewer.txt",
      "permission": {
        "edit": "deny"
      }
    },
    "planner": {
      "description": "Custom planner description",
      "promptPath": "custom/path/to/planner.txt",
      "permission": {
        "edit": "deny"
      }
    }
  },

  "tools": {
    "enabled": ["changes_load", "pr_load", "ticket_create", "ticket_load"]
  },

  "components": {
    "enabled": ["change-summary", "commit", "dev-flow"],
    "paths": {
      "dev-flow": "custom/path/to/dev-flow.txt"
    }
  },

  "defaults": {
    "baseBranch": "main"
  },

  "adapters": {
    "opencode": {
      "agentMode": "all"
    }
  }
}
