{
  "name": "@kompassdev/core",
  "version": "0.0.3",
  "description": "Shared Kompass workflows, prompts, components, and tool definitions",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "agents",
    "commands",
    "components",
    "dist",
    "kompass.jsonc",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./index.ts --outdir ./dist --target node --format esm --packages external",
    "prepack": "bun run build",
    "test": "bun test test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "kompass",
    "workflow",
    "ai",
    "toolkit",
    "agents"
  ],
  "license": "MIT",
  "dependencies": {
    "eta": "^4.5.1"
  }
}
