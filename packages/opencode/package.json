{
  "name": "@kompassdev/opencode",
  "version": "0.8.2",
  "description": "OpenCode plugin for navigating repos with fewer wrong turns",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "agents",
    "commands",
    "components",
    "dist",
    "kompass.jsonc",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run ./scripts/build.ts",
    "check": "bun --eval \"await import('./index.ts')\"",
    "compile": "bun run ./scripts/compile.ts",
    "prepack": "bun run build",
    "test": "bun test test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "opencode",
    "coding-agent",
    "ai-agent",
    "developer-tools",
    "workflow",
    "code-review",
    "pull-request",
    "ticketing",
    "automation",
    "kompass"
  ],
  "homepage": "https://github.com/kompassdev/kompass#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kompassdev/kompass.git",
    "directory": "packages/opencode"
  },
  "bugs": {
    "url": "https://github.com/kompassdev/kompass/issues"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.2.25"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.25",
    "@opencode-ai/sdk": "^1.2.25",
    "yaml": "^2.8.2"
  }
}
