---
// Command showcase with parent/child session hierarchy
interface ToolCall {
  tool: string;
  args: string;
  status: 'pending' | 'running' | 'complete';
}

interface SessionStep {
  id: string;
  phase: 'thinking' | 'tool_calls' | 'output';
  content?: string;
  toolCalls?: ToolCall[];
  output?: string[];
}

interface CommandScenario {
  id: string;
  label: string;
  command: string;
  agentName: string;
  task: string;
  steps: SessionStep[];
}

