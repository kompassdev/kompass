    id: 'todo',
    label: '/todo',
    command: '/todo @TODO.md',
    agentName: 'Navigator',
    task: 'Work through a todo file one item at a time',
    group: 'orchestration',
    steps: [
      { id: 'thinking', phase: 'thinking', content: 'Take the first unchecked item only, plan it, get approval, implement it, commit it, mark it complete, and loop.' },
      { id: 'tools', phase: 'tool_calls', toolCalls: [
        { tool: 'read', args: '@TODO.md', status: 'complete' },
        { tool: 'dispatch', args: 'planner · /ticket/plan', status: 'complete' },
        { tool: 'question', args: 'Plan Review', status: 'complete' },
        { tool: 'dispatch', args: 'worker · /dev', status: 'complete' },
        { tool: 'dispatch', args: 'worker · /commit', status: 'complete' }
      ] },
      { id: 'output', phase: 'output', output: [
        'Todo complete: @TODO.md',
        'Remaining: 0',
        'No additional steps are required.'
