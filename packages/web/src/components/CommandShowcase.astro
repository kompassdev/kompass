---
// Command showcase with working tabs - each command shows its own scenario
interface ToolCall {
  tool: string;
  args: string;
  status: 'pending' | 'running' | 'complete';
}

interface SessionStep {
  id: string;
  phase: 'thinking' | 'tool_calls' | 'output';
  content?: string;
  toolCalls?: ToolCall[];
  output?: string[];
}

interface CommandScenario {
  id: string;
  label: string;
  command: string;
  agentName: string;
  task: string;
  steps: SessionStep[];
}

const scenarios: CommandScenario[] = [
  {
    id: 'ask',
    label: '/ask',
    command: '/ask is this project cool?',
    agentName: 'Build Agent',
    task: 'Answer questions about the current project or code',
    steps: [
      {
        id: 'thinking',
        phase: 'thinking',
        content: 'Evaluating project appeal — need to determine if this project is cool by inspecting repository structure, README, and command architecture. Will check relevant files and keep analysis concise.'
      },
      {
        id: 'tools',
        phase: 'tool_calls',
        toolCalls: [
          { tool: 'glob', args: 'README* in . (5 matches)', status: 'complete' },
          { tool: 'read', args: 'package.json', status: 'complete' },
          { tool: 'read', args: 'README.md [limit=220]', status: 'complete' },
          { tool: 'read', args: 'packages/core/README.md [limit=220]', status: 'complete' }
        ]
      },
      {
        id: 'output',
        phase: 'output',
        output: [
          'It has a clear point of view: keep AI coding agents "on course" with token-efficient, composable workflows instead of giant ad-hoc prompts.',
          'The repo is structured thoughtfully: shared logic lives in packages/core, adapter-specific wiring in packages/opencode.',
          'The command surface is unusually coherent — /ask, /review, /pr/create, /ticket/plan all fit the same workflow philosophy.',
          'No additional steps are required.'
        ]
      }
    ]
  },
  {
    id: 'ticket-plan',
    label: '/ticket/plan',
    command: '/ticket/plan #128 rollout the new review workflow',
    agentName: 'Planner',
    task: 'Turn a request or ticket into a scoped implementation plan',
    steps: [
      {
        id: 'thinking',
        phase: 'thinking',
        content: 'Planning the rollout — need to break down the review workflow into actionable steps. Will examine existing patterns and create a scoped plan with clear milestones.'
      },
      {
        id: 'tools',
        phase: 'tool_calls',
        toolCalls: [
          { tool: 'ticket_load', args: '#128', status: 'complete' },
          { tool: 'read', args: 'packages/core/commands/pr/review.md', status: 'complete' },
          { tool: 'glob', args: 'packages/core/components/*.md', status: 'complete' }
        ]
      },
      {
        id: 'output',
        phase: 'output',
        output: [
          'Phase 1: Extract reusable review components from existing commands',
          'Phase 2: Update navigator agent to coordinate review workflows',
          'Phase 3: Add checklist generation and feedback threading',
          'Plan ready for implementation. No additional steps required.'
        ]
      }
    ]
  },
  {
    id: 'pr-create',
    label: '/pr/create',
    command: '/pr/create',
    agentName: 'Navigator',
    task: 'Summarize branch work and publish a structured PR',
    steps: [
      {
        id: 'thinking',
        phase: 'thinking',
        content: 'Creating PR — need to load branch changes, check for linked tickets, and generate a structured PR description with checklist sections.'
      },
      {
        id: 'tools',
        phase: 'tool_calls',
        toolCalls: [
          { tool: 'changes_load', args: 'HEAD...main', status: 'complete' },
          { tool: 'ticket_load', args: '#42', status: 'complete' },
          { tool: 'bash', args: 'git push origin HEAD', status: 'complete' }
        ]
      },
      {
        id: 'output',
        phase: 'output',
        output: [
          'Created PR #47: Add workflow visualization to homepage',
          'Linked to ticket #42 with structured checklist',
          'PR body includes summary, changes, and testing notes',
          'No additional steps are required.'
        ]
      }
    ]
  },
  {
    id: 'review',
    label: '/review',
    command: '/review',
    agentName: 'Reviewer',
    task: 'Review branch changes without editing files',
    steps: [
      {
        id: 'thinking',
        phase: 'thinking',
        content: 'Reviewing changes — need to load the diff context and examine modified files for potential issues, risks, and improvements without making edits.'
      },
      {
        id: 'tools',
        phase: 'tool_calls',
        toolCalls: [
          { tool: 'changes_load', args: 'uncommitted', status: 'complete' },
          { tool: 'read', args: 'packages/web/src/components/CommandShowcase.astro', status: 'complete' },
          { tool: 'task', args: 'reviewer analysis', status: 'complete' }
        ]
      },
      {
        id: 'output',
        phase: 'output',
        output: [
          'Strong separation of concerns between scenarios and rendering',
          'Consider adding error handling for failed tool calls',
          'Animation timing is appropriate for the UX flow',
          'No additional steps are required.'
        ]
      }
    ]
  },
  {
    id: 'dev',
    label: '/dev',
    command: '/dev implement the approved workflow in packages/core',
    agentName: 'Worker',
    task: 'Implement approved plans with validation',
    steps: [
      {
        id: 'thinking',
        phase: 'thinking',
        content: 'Implementing workflow — loading ticket context and executing the approved plan. Will edit only relevant files and validate changes as I go.'
      },
      {
        id: 'tools',
        phase: 'tool_calls',
        toolCalls: [
          { tool: 'ticket_load', args: '#128', status: 'complete' },
          { tool: 'apply_patch', args: 'packages/core/commands/pr/review.md', status: 'complete' },
          { tool: 'bash', args: 'npm run typecheck', status: 'complete' }
        ]
      },
      {
        id: 'output',
        phase: 'output',
        output: [
          'Implemented review workflow in packages/core/commands/pr/',
          'Added navigator coordination and feedback threading',
          'All validation checks passed successfully',
          'No additional steps are required.'
        ]
      }
    ]
  }
];

const allCommands = [
  "/ask", "/branch", "/commit", "/commit-and-push", "/dev", "/learn", 
  "/reload", "/pr/create", "/pr/fix", "/pr/review", "/review", "/ship",
  "/rmslop", "/todo", "/ticket/ask", "/ticket/create", "/ticket/dev", "/ticket/plan"
];
---

<div class="command-showcase" data-command-showcase>
  <div class="command-showcase__background" aria-hidden="true">
    <div class="command-showcase__grid"></div>
    <div class="command-showcase__glow command-showcase__glow--top"></div>
    <div class="command-showcase__glow command-showcase__glow--bottom"></div>
    <div class="command-showcase__orbit command-showcase__orbit--outer"></div>
    <div class="command-showcase__orbit command-showcase__orbit--inner"></div>
  </div>

  <div class="command-showcase__main">
    <!-- Tab navigation -->
    <div class="command-strip" role="tablist" aria-label="Command examples">
      {scenarios.map((scenario, index) => (
        <button 
          type="button"
          class:list={{ "command-tab": true, "is-active": index === 0 }}
          role="tab"
          aria-selected={index === 0 ? "true" : "false"}
          aria-controls={`panel-${scenario.id}`}
          id={`tab-${scenario.id}`}
          data-command-tab={scenario.id}
        >
          {scenario.label}
        </button>
      ))}
    </div>

    <!-- All scenario panels -->
    {scenarios.map((scenario, index) => (
      <div 
        class:list={{ "scenario-panel": true, "is-active": index === 0 }}
        role="tabpanel"
        aria-labelledby={`tab-${scenario.id}`}
        id={`panel-${scenario.id}`}
        data-scenario-panel={scenario.id}
        hidden={index !== 0}
      >
        <div class="session-terminal">
          <div class="session-terminal__header">
            <div class="session-terminal__window-controls">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="session-terminal__title">
              <span class="session-terminal__status" data-status-dot></span>
              <span data-session-title>{scenario.agentName}</span>
            </div>
            <div class="session-terminal__meta">
              <span data-tool-count>0 toolcalls</span>
              <span data-session-time>0.0s</span>
            </div>
          </div>

          <div class="session-terminal__body">
            <!-- Command Input -->
            <div class="session-line session-line--input">
              <span class="session-line__prompt">$</span>
              <span class="session-line__command" data-typewriter>{scenario.command}</span>
            </div>

            <!-- Task Description -->
            <div class="session-line session-line--task">
              <span class="session-line__icon">◆</span>
              <span>{scenario.task}</span>
            </div>

            <!-- Session Steps -->
            <div class="session-steps" data-session-steps>
              {scenario.steps.map((step) => (
                <div class="session-step" data-step={step.id}>
                  {step.phase === 'thinking' && step.content && (
                    <div class="thinking-block">
                      <div class="thinking-block__header">
                        <span class="thinking-block__indicator">
                          <span class="thinking-block__pulse"></span>
                        </span>
                        <span class="thinking-block__label">Thinking</span>
                      </div>
                      <p class="thinking-block__content">{step.content}</p>
                    </div>
                  )}

                  {step.phase === 'tool_calls' && step.toolCalls && (
                    <div class="tool-calls-block">
                      <div class="tool-calls-block__header">
                        <span class="tool-calls-block__icon">▸</span>
                        <span class="tool-calls-block__label">Explored</span>
                        <span class="tool-calls-block__count">{step.toolCalls.length} reads, 1 search</span>
                      </div>
                      <div class="tool-calls-block__list">
                        {step.toolCalls.map((tool) => (
                          <div class="tool-call" data-tool-status={tool.status}>
                            <span class="tool-call__arrow">→</span>
                            <span class="tool-call__name">{tool.tool}</span>
                            <span class="tool-call__args">{tool.args}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {step.phase === 'output' && step.output && (
                    <div class="output-block">
                      {step.output.map((line) => (
                        <p class="output-block__line">{line}</p>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>

            <!-- Navigation hint -->
            <div class="session-nav-hint">
              <span>Parent <kbd>↑</kbd></span>
              <span>Prev <kbd>←</kbd></span>
              <span>Next <kbd>→</kbd></span>
            </div>
          </div>
        </div>
      </div>
    ))}

    <!-- All commands strip (decorative) -->
    <div class="all-commands" aria-hidden="true">
      {allCommands.map((cmd) => (
        <span class="command-pill-decorative">{cmd}</span>
      ))}
    </div>
  </div>
</div>

<script>
  // Typewriter effect
  function typewriter(element: HTMLElement, text: string, speed: number = 30) {
    let i = 0;
    element.textContent = '';
    return new Promise<void>((resolve) => {
      const timer = setInterval(() => {
        if (i < text.length) {
          element.textContent += text.charAt(i);
          i++;
        } else {
          clearInterval(timer);
          resolve();
        }
      }, speed);
    });
  }

  // Reset and animate a scenario panel
  async function animateScenario(panel: HTMLElement) {
    const typewriterEl = panel.querySelector('[data-typewriter]') as HTMLElement;
    const steps = panel.querySelectorAll('[data-step]');
    const statusDot = panel.querySelector('[data-status-dot]') as HTMLElement;
    const toolCount = panel.querySelector('[data-tool-count]') as HTMLElement;
    const sessionTime = panel.querySelector('[data-session-time]') as HTMLElement;
    const navHint = panel.querySelector('.session-nav-hint') as HTMLElement;
    
    // Reset all animations
    steps.forEach(step => step.classList.remove('is-visible'));
    panel.querySelectorAll('.tool-call').forEach(tool => tool.classList.remove('is-visible'));
    panel.querySelectorAll('.output-block__line').forEach(line => line.classList.remove('is-visible'));
    if (statusDot) statusDot.classList.remove('is-complete');
    if (navHint) navHint.style.opacity = '0';
    
    let toolcallCounter = 0;
    let startTime = Date.now();
    
    function updateTimer() {
      const elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
      if (sessionTime) sessionTime.textContent = `${elapsed}s`;
    }
    
    const timerInterval = window.setInterval(updateTimer, 100);
    
    // Type the command
    if (typewriterEl) {
      await typewriter(typewriterEl, typewriterEl.textContent || '', 35);
    }
    
    // Animate through each step
    for (let i = 0; i < steps.length; i++) {
      const step = steps[i] as HTMLElement;
      await new Promise(resolve => setTimeout(resolve, 350));
      step.classList.add('is-visible');
      
      if (step.dataset.step === 'tools') {
        const tools = step.querySelectorAll('.tool-call');
        for (let j = 0; j < tools.length; j++) {
          await new Promise(resolve => setTimeout(resolve, 250));
          tools[j].classList.add('is-visible');
          toolcallCounter++;
          if (toolCount) toolCount.textContent = `${toolcallCounter} toolcalls`;
        }
        await new Promise(resolve => setTimeout(resolve, 400));
      }
      
      if (step.dataset.step === 'output') {
        const lines = step.querySelectorAll('.output-block__line');
        for (let j = 0; j < lines.length; j++) {
          await new Promise(resolve => setTimeout(resolve, 180));
          lines[j].classList.add('is-visible');
        }
      }
    }
    
    clearInterval(timerInterval);
    if (statusDot) statusDot.classList.add('is-complete');
    if (navHint) navHint.style.opacity = '1';
  }

  // Initialize showcase
  function initShowcase() {
    const showcase = document.querySelector('[data-command-showcase]');
    if (!showcase) return;
    
    const tabs = showcase.querySelectorAll('[data-command-tab]');
    const panels = showcase.querySelectorAll('[data-scenario-panel]');
    
    // Tab switching
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetId = tab.getAttribute('data-command-tab');
        if (!targetId) return;
        
        // Update tab states
        tabs.forEach(t => {
          const isActive = t.getAttribute('data-command-tab') === targetId;
          t.classList.toggle('is-active', isActive);
          t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        
        // Update panel visibility
        panels.forEach(panel => {
          const isActive = panel.getAttribute('data-scenario-panel') === targetId;
          panel.classList.toggle('is-active', isActive);
          panel.toggleAttribute('hidden', !isActive);
          
          if (isActive) {
            animateScenario(panel as HTMLElement);
          }
        });
      });
    });
    
    // Animate first panel on load
    const firstPanel = showcase.querySelector('[data-scenario-panel]') as HTMLElement;
    if (firstPanel) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateScenario(firstPanel);
            observer.disconnect();
          }
        });
      }, { threshold: 0.2 });
      observer.observe(showcase);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShowcase);
  } else {
    initShowcase();
  }
</script>

<style>
  .command-showcase {
    position: relative;
    width: 100%;
    min-height: 32rem;
    padding: 2rem 0;
  }

  .command-showcase__background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .command-showcase__grid {
    position: absolute;
    inset: 5% 4%;
    background-image:
      linear-gradient(rgba(159, 179, 195, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(159, 179, 195, 0.06) 1px, transparent 1px);
    background-size: 2.4rem 2.4rem;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    animation: gridDrift 20s ease-in-out infinite;
  }

  @keyframes gridDrift {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(8px) rotate(0.5deg); }
  }

  .command-showcase__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.4;
    animation: glowPulse 8s ease-in-out infinite;
  }

  .command-showcase__glow--top {
    inset: -10% 60% auto auto;
    width: 20rem;
    height: 20rem;
    background: radial-gradient(circle, rgba(248, 184, 78, 0.3), transparent 70%);
  }

  .command-showcase__glow--bottom {
    inset: auto auto -10% 40%;
    width: 16rem;
    height: 16rem;
    background: radial-gradient(circle, rgba(95, 158, 197, 0.25), transparent 70%);
    animation-delay: -4s;
  }

  @keyframes glowPulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.1); }
  }

  .command-showcase__orbit {
    position: absolute;
    border: 1px solid rgba(125, 166, 196, 0.1);
    border-radius: 50%;
  }

  .command-showcase__orbit--outer {
    inset: 5% 10% 20% 15%;
    animation: orbitRotate 30s linear infinite;
  }

  .command-showcase__orbit--inner {
    inset: 20% 20% 10% 10%;
    animation: orbitRotate 20s linear infinite reverse;
  }

  @keyframes orbitRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .command-showcase__main {
    position: relative;
    z-index: 1;
  }

  /* Tabs */
  .command-strip {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.6rem;
    justify-content: center;
    margin-bottom: 1.5rem;
    padding: 0 1rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .command-strip::-webkit-scrollbar {
    display: none;
  }

  .command-tab {
    flex-shrink: 0;
    padding: 0.55rem 0.9rem;
    border: 1px solid rgba(125, 166, 196, 0.15);
    border-radius: 999px;
    background: rgba(8, 18, 29, 0.6);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
  }

  .command-tab:hover {
    border-color: rgba(248, 184, 78, 0.35);
    background: rgba(248, 184, 78, 0.12);
    color: var(--text);
    transform: translateY(-1px);
  }

  .command-tab.is-active {
    border-color: rgba(248, 184, 78, 0.45);
    background: rgba(248, 184, 78, 0.18);
    color: var(--text);
  }

  /* Scenario panels */
  .scenario-panel {
    display: none;
  }

  .scenario-panel.is-active {
    display: block;
  }

  /* Decorative command strip */
  .all-commands {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    justify-content: center;
    margin-top: 2rem;
    padding: 0 1rem;
    overflow-x: auto;
    opacity: 0.5;
    scrollbar-width: none;
  }

  .all-commands::-webkit-scrollbar {
    display: none;
  }

  .command-pill-decorative {
    flex-shrink: 0;
    padding: 0.4rem 0.7rem;
    border: 1px solid rgba(125, 166, 196, 0.1);
    border-radius: 999px;
    background: rgba(8, 18, 29, 0.4);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  /* Terminal styles */
  .session-terminal {
    max-width: 900px;
    margin: 0 auto;
    border: 1px solid rgba(125, 166, 196, 0.12);
    border-radius: 1rem;
    background:
      radial-gradient(circle at 80% 5%, rgba(248, 184, 78, 0.05), transparent 25%),
      linear-gradient(180deg, rgba(5, 12, 20, 0.9), rgba(7, 17, 28, 0.85));
    box-shadow: 
      0 24px 80px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.03);
    overflow: hidden;
  }

  .session-terminal__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.2rem;
    border-bottom: 1px solid rgba(125, 166, 196, 0.08);
    background: rgba(0, 0, 0, 0.2);
  }

  .session-terminal__window-controls {
    display: flex;
    gap: 0.4rem;
  }

  .session-terminal__window-controls span {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: rgba(159, 179, 195, 0.4);
  }

  .session-terminal__title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex: 1;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text);
  }

  .session-terminal__status {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #f8b84e;
    box-shadow: 0 0 8px rgba(248, 184, 78, 0.6);
    animation: statusPulse 2s ease-in-out infinite;
  }

  .session-terminal__status.is-complete {
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.6);
    animation: none;
  }

  @keyframes statusPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.9); }
  }

  .session-terminal__meta {
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
  }

  .session-terminal__body {
    padding: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .session-line {
    margin-bottom: 0.8rem;
  }

  .session-line--input {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text);
  }

  .session-line__prompt {
    color: var(--accent);
    font-weight: 500;
  }

  .session-line__command {
    color: #d8e5ee;
  }

  .session-line--task {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .session-line__icon {
    color: var(--accent);
  }

  .session-steps {
    margin-top: 1rem;
  }

  .session-step {
    opacity: 0;
    transform: translateY(12px);
    transition: all 0.4s ease;
  }

  .session-step.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .thinking-block {
    margin-bottom: 1rem;
    padding: 1rem;
    border-left: 2px solid rgba(248, 184, 78, 0.4);
    background: rgba(248, 184, 78, 0.05);
  }

  .thinking-block__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .thinking-block__indicator {
    position: relative;
    width: 0.6rem;
    height: 0.6rem;
  }

  .thinking-block__pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--accent);
    animation: thinkingPulse 1.5s ease-in-out infinite;
  }

  @keyframes thinkingPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
  }

  .thinking-block__label {
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .thinking-block__content {
    margin: 0;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.7;
    font-style: italic;
  }

  .tool-calls-block {
    margin-bottom: 1rem;
