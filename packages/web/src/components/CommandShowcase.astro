// Split scenarios into two groups
const commandScenarios = scenarios.filter(s => ['ask', 'branch', 'commit', 'commit-and-push', 'dev', 'learn', 'reload', 'review', 'rmslop'].includes(s.id));
const orchestratorScenarios = scenarios.filter(s => ['pr-create', 'pr-fix', 'pr-review', 'ship', 'todo', 'ticket-plan'].includes(s.id));

---

<div class="command-showcase" data-command-showcase>
  <div class="command-showcase__background" aria-hidden="true">
    <div class="command-showcase__grid"></div>
    <div class="command-showcase__glow command-showcase__glow--top"></div>
    <div class="command-showcase__glow command-showcase__glow--bottom"></div>
    <div class="command-showcase__orbit command-showcase__orbit--outer"></div>
    <div class="command-showcase__orbit command-showcase__orbit--inner"></div>
  </div>

  <div class="command-showcase__main">
    <!-- Combined Tab navigation with groups -->
    <div class="command-strip-wrapper">
      <div class="command-strip" role="tablist" aria-label="Command examples">
        <span class="command-group-label">Commands</span>
        {commandScenarios.map((scenario, index) => (
          <button 
            type="button"
            class:list={{ "command-tab": true, "is-active": index === 0 }}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            aria-controls={`panel-${scenario.id}`}
            id={`tab-${scenario.id}`}
            data-command-tab={scenario.id}
          >
            {scenario.label}
          </button>
        ))}
        <span class="command-group-divider"></span>
        <span class="command-group-label command-group-label--orchestrators">Orchestrators</span>
        {orchestratorScenarios.map((scenario) => (
          <button 
            type="button"
            class:list={{ "command-tab command-tab--orchestrator": true }}
            role="tab"
            aria-selected="false"
            aria-controls={`panel-${scenario.id}`}
            id={`tab-${scenario.id}`}
            data-command-tab={scenario.id}
          >
            {scenario.label}
          </button>
        ))}
      </div>
    </div>

    <!-- All scenario panels -->
    {scenarios.map((scenario, index) => (
      <div 
        class:list={{ "scenario-panel": true, "is-active": index === 0 }}
        role="tabpanel"
        aria-labelledby={`tab-${scenario.id}`}
        id={`panel-${scenario.id}`}
        data-scenario-panel={scenario.id}
        hidden={index !== 0}
      >
        <div class="session-terminal">
          <!-- Parent Session Header -->
          <div class="session-terminal__header session-terminal__header--parent">
            <div class="session-terminal__parent-info">
              <span class="session-terminal__prompt">$</span>
              <span class="session-terminal__command" data-typewriter>{scenario.command}</span>
            </div>
            <div class="session-terminal__meta">
              <span class="session-terminal__status" data-status-dot></span>
            </div>
          </div>

          <!-- Subagent Session -->
          <div class="subagent-session" data-subagent-session>
            <!-- Subagent Header -->
            <div class="subagent-session__header">
              <div class="subagent-session__title">
                <span class="subagent-session__indicator"></span>
                <span class="subagent-session__agent">{scenario.agentName}</span>
                <span class="subagent-session__divider">—</span>
                <span class="subagent-session__task">{scenario.task}</span>
              </div>
              <div class="subagent-session__stats">
                <span data-tool-count>0 toolcalls</span>
              </div>
            </div>

            <!-- Subagent Body -->
            <div class="subagent-session__body">
              <!-- Session Steps -->
              <div class="session-steps" data-session-steps>
                {scenario.steps.map((step) => (
                  <div class="session-step" data-step={step.id}>
                    {step.phase === 'thinking' && step.content && (
                      <div class="thinking-block">
                        <div class="thinking-block__header">
                          <span class="thinking-block__indicator">
                            <span class="thinking-block__pulse"></span>
                          </span>
                          <span class="thinking-block__label">Thinking</span>
                        </div>
                        <p class="thinking-block__content">{step.content}</p>
                      </div>
                    )}

                    {step.phase === 'tool_calls' && step.toolCalls && (
                      <div class="tool-calls-block">
                        <div class="tool-calls-block__header">
                          <span class="tool-calls-block__icon">▸</span>
                          <span class="tool-calls-block__label">
                            {step.toolCalls.some(t => t.tool === 'dispatch') ? 'Delegated' : 'Explored'}
                          </span>
                          <span class="tool-calls-block__count">
                            {step.toolCalls.length} {step.toolCalls.some(t => t.tool === 'dispatch') ? 'subagents' : 'reads, 1 search'}
                          </span>
                        </div>
                        <div class="tool-calls-block__list">
                          {step.toolCalls.map((tool) => (
                            <div class:list={{ "tool-call": true, "tool-call--dispatch": tool.tool === 'dispatch' }} data-tool-status={tool.status}>
                              {tool.tool === 'dispatch' ? (
                                <>
                                  <span class="tool-call__indicator"></span>
                                  <span class="tool-call__dispatch-cmd">{tool.args}</span>
                                </>
                              ) : (
                                <>
                                  <span class="tool-call__arrow">→</span>
                                  <span class="tool-call__name">{tool.tool}</span>
                                  <span class="tool-call__args">{tool.args}</span>
                                </>
                              )}
                            </div>
                          ))}
                        </div>
                      </div>
                    )}

                    {step.phase === 'output' && step.output && (
                      <div class="output-block">
                        {step.output.map((line) => (
                          <p class="output-block__line">{line}</p>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Parent Session Output -->
          <div class="parent-output" data-parent-output>
            {scenario.steps.find(s => s.phase === 'output')?.output?.map((line) => (
              <p class="parent-output__line">{line}</p>
            ))}
          </div>
        </div>
      </div>
    ))}

    </div>
</div>

<script>
  // Typewriter effect
  function typewriter(element: HTMLElement, text: string, speed: number = 30) {
    let i = 0;
    element.textContent = '';
    return new Promise<void>((resolve) => {
      const timer = setInterval(() => {
        if (i < text.length) {
          element.textContent += text.charAt(i);
          i++;
        } else {
          clearInterval(timer);
          resolve();
        }
      }, speed);
    });
  }

  // Reset and animate a scenario panel
  async function animateScenario(panel: HTMLElement) {
    const typewriterEl = panel.querySelector('[data-typewriter]') as HTMLElement;
    const steps = panel.querySelectorAll('[data-step]');
    const statusDot = panel.querySelector('[data-status-dot]') as HTMLElement;
    const toolCount = panel.querySelector('[data-tool-count]') as HTMLElement;
    const parentOutput = panel.querySelector('[data-parent-output]') as HTMLElement;
    const subagentSession = panel.querySelector('[data-subagent-session]') as HTMLElement;
    
    // Reset all animations
    steps.forEach(step => step.classList.remove('is-visible'));
    panel.querySelectorAll('.tool-call').forEach(tool => tool.classList.remove('is-visible'));
    panel.querySelectorAll('.output-block__line').forEach(line => line.classList.remove('is-visible'));
    panel.querySelectorAll('.parent-output__line').forEach(line => line.classList.remove('is-visible'));
    if (statusDot) statusDot.classList.remove('is-complete');
    if (parentOutput) parentOutput.classList.remove('is-visible');
    if (subagentSession) subagentSession.classList.remove('is-visible');
    
    let toolcallCounter = 0;
    
    // Type the command
    if (typewriterEl) {
      await typewriter(typewriterEl, typewriterEl.textContent || '', 35);
    }
    
    // Delay then show subagent session
    await new Promise(resolve => setTimeout(resolve, 600));
    if (subagentSession) {
      subagentSession.classList.add('is-visible');
    }
    
    // Animate through each subagent step
    for (let i = 0; i < steps.length; i++) {
      const step = steps[i] as HTMLElement;
      await new Promise(resolve => setTimeout(resolve, 350));
      step.classList.add('is-visible');
      
      if (step.dataset.step === 'tools') {
        const tools = step.querySelectorAll('.tool-call');
        for (let j = 0; j < tools.length; j++) {
          await new Promise(resolve => setTimeout(resolve, 250));
          tools[j].classList.add('is-visible');
          toolcallCounter++;
          if (toolCount) toolCount.textContent = `${toolcallCounter} toolcalls`;
        }
        await new Promise(resolve => setTimeout(resolve, 400));
      }
      
      if (step.dataset.step === 'output') {
        const lines = step.querySelectorAll('.output-block__line');
        for (let j = 0; j < lines.length; j++) {
          await new Promise(resolve => setTimeout(resolve, 180));
          lines[j].classList.add('is-visible');
        }
      }
    }
    
    // Show parent output after subagent completes
    await new Promise(resolve => setTimeout(resolve, 400));
    if (parentOutput) {
      parentOutput.classList.add('is-visible');
      const lines = parentOutput.querySelectorAll('.parent-output__line');
      for (let j = 0; j < lines.length; j++) {
        await new Promise(resolve => setTimeout(resolve, 150));
        lines[j].classList.add('is-visible');
      }
    }
    
    if (statusDot) statusDot.classList.add('is-complete');
  }

  // Initialize showcase
  function initShowcase() {
    const showcase = document.querySelector('[data-command-showcase]');
    if (!showcase) return;
    
    const tabs = showcase.querySelectorAll('[data-command-tab]');
    const panels = showcase.querySelectorAll('[data-scenario-panel]');
    
    // Tab switching
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetId = tab.getAttribute('data-command-tab');
        if (!targetId) return;
        
        // Update tab states
        tabs.forEach(t => {
          const isActive = t.getAttribute('data-command-tab') === targetId;
          t.classList.toggle('is-active', isActive);
          t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        
        // Update panel visibility
        panels.forEach(panel => {
          const isActive = panel.getAttribute('data-scenario-panel') === targetId;
          panel.classList.toggle('is-active', isActive);
          panel.toggleAttribute('hidden', !isActive);
          
          if (isActive) {
            animateScenario(panel as HTMLElement);
          }
        });
      });
    });
    
    // Animate first panel on load
    const firstPanel = showcase.querySelector('[data-scenario-panel]') as HTMLElement;
    if (firstPanel) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateScenario(firstPanel);
            observer.disconnect();
          }
        });
      }, { threshold: 0.2 });
      observer.observe(showcase);
    }
  }

