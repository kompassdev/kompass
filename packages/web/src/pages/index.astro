---
import CommandShowcase from "../components/CommandShowcase.astro";
import InstallBlock from "../components/InstallBlock.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";



const heroHighlights = [
  {
    eyebrow: "Core",
    title: "Commands, agents, components, tools"
  },
  {
    eyebrow: "Adapters",
    title: "OpenCode today, more surfaces next"
  },
  {
    eyebrow: "Integrations",
    title: "GitHub workflows, tickets, PRs, review loops"
  }
];

---

<MarketingLayout title="Kompass - Navigate AI coding work with intent">
  <main class="landing-page">
    <section class="hero">
      <header class="site-header">
        <a class="brand" href="/">
          <img src="/kompass-icon.png" alt="" width="40" height="40" />
          <span>Kompass</span>
        </a>
        <nav>
          <a href="#commands">Commands</a>
          <a class="nav-button nav-button--docs" href="/docs/">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M6.75 3.75A2.25 2.25 0 0 0 4.5 6v12A2.25 2.25 0 0 0 6.75 20.25H18a1.5 1.5 0 0 0 1.5-1.5V7.81a2.25 2.25 0 0 0-.66-1.59l-1.06-1.06a2.25 2.25 0 0 0-1.59-.66H6.75Zm8.25 1.6c.42.1.8.31 1.1.62l1.93 1.93H15a.75.75 0 0 1-.75-.75V5.35Zm-7.5 3.9a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 0 1.5h-3a.75.75 0 0 1-.75-.75Zm0 3.75a.75.75 0 0 1 .75-.75h7.5a.75.75 0 0 1 0 1.5h-7.5a.75.75 0 0 1-.75-.75Zm0 3.75a.75.75 0 0 1 .75-.75h7.5a.75.75 0 0 1 0 1.5h-7.5a.75.75 0 0 1-.75-.75Z"
                fill="currentColor"
              ></path>
            </svg>
            <span>Docs</span>
          </a>
          <a class="nav-button nav-button--github" href="https://github.com/kompassdev/kompass" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M12 2.25a9.75 9.75 0 0 0-3.08 19c.49.09.67-.21.67-.47v-1.66c-2.73.59-3.3-1.17-3.3-1.17-.44-1.13-1.08-1.43-1.08-1.43-.88-.6.07-.59.07-.59.97.07 1.48 1 1.48 1 .87 1.48 2.27 1.06 2.82.81.09-.63.34-1.06.61-1.3-2.18-.25-4.47-1.09-4.47-4.85 0-1.07.38-1.95 1-2.63-.1-.25-.43-1.27.1-2.64 0 0 .82-.26 2.7 1a9.35 9.35 0 0 1 4.91 0c1.87-1.26 2.69-1 2.69-1 .54 1.37.21 2.39.11 2.64.62.68 1 1.56 1 2.63 0 3.77-2.29 4.59-4.48 4.84.35.3.66.9.66 1.82v2.7c0 .26.18.56.68.47A9.75 9.75 0 0 0 12 2.25Z"
                fill="currentColor"
              ></path>
            </svg>
            <span>GitHub</span>
          </a>
        </nav>
      </header>

      <div class="hero__content">
        <div class="hero__copy">
          <p class="eyebrow">Workflow infrastructure for AI coding agents</p>
          <h1>Navigate your way.</h1>
          <p class="hero__lede">
            Manual steering, steered autonomy, or full autonomy. Kompass keeps AI coding agents on course with
            token-efficient, composable workflows.
          </p>
          <div class="hero__actions">
            <a class="button button--primary" href="/docs/">Start with the docs</a>
            <a class="button button--ghost" href="https://github.com/kompassdev/kompass" target="_blank" rel="noopener">View the repo</a>
          </div>
        </div>

        <div class="hero__install" aria-label="Installation">
          <InstallBlock />
        </div>
      </div>

      <div class="hero__showcase" id="commands">
        <CommandShowcase />
      </div>

      <div class="hero__highlights" aria-label="Kompass highlights">
        {heroHighlights.map((item) => (
          <article class="hero-highlight">
            <p class="eyebrow">{item.eyebrow}</p>
            <h2>{item.title}</h2>
          </article>
        ))}
      </div>
    </section>

    <footer class="section site-footer">
      <div class="site-footer__brand">
        <p class="eyebrow">Kompass</p>
        <h2>Structured workflows for AI coding agents.</h2>
        <p>
          Manual steering, collaborative execution, or guided autonomy - one workflow language across planning,
          development, review, and shipping.
        </p>
      </div>

      <div class="site-footer__links">
        <div>
          <p class="eyebrow">Explore</p>
          <a href="/docs/">Overview</a>
          <a href="/docs/architecture/">Architecture</a>
          <a href="/docs/adapters/opencode/">OpenCode</a>
        </div>
        <div>
          <p class="eyebrow">Reference</p>
          <a href="/docs/reference/commands/">Commands</a>
          <a href="/docs/reference/agents/">Agents</a>
          <a href="/docs/reference/tools/">Tools</a>
        </div>
      </div>
    </footer>
  </main>
</MarketingLayout>
